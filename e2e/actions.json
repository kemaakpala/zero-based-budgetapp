{
  "actions": [
    {
      "type": "goto",
      "url": "/settings"
    },
    {
      "type": "wait",
      "selector": "h2:has-text('Set Your Starting Monthly Income')"
    },
    {
      "type": "screenshot",
      "selector": ".setup-wizard-container",
      "path": "screenshots/step1_salary.png"
    },
    {
      "type": "click",
      "selector": "button:has-text('Next')"
    },
    {
      "type": "wait",
      "selector": "h2:has-text('Customize Budget Categories')"
    },
    {
      "type": "wait",
      "timeout": 500
    },
    {
      "type": "screenshot",
      "selector": ".setup-wizard-container",
      "path": "screenshots/step2_categories.png"
    },
    {
      "type": "click",
      "selector": "button:has-text('Next')"
    },
    {
      "type": "wait",
      "selector": "h2:has-text('Do You Have Any Debt?')"
    },
    {
      "type": "click",
      "selector": "button:has-text('No, skip this step')"
    },
    {
      "type": "wait",
      "selector": "h2:has-text('Do You Want to Set Up Savings Goals?')"
    },
    {
      "type": "click",
      "selector": "button:has-text('No, skip this step')"
    },
    {
      "type": "wait",
      "selector": "h2:has-text('Confirm Your Budget Setup')"
    },
    {
      "type": "screenshot",
      "selector": ".setup-wizard-container",
      "path": "screenshots/step5_confirm.png"
    }
  ]
}
